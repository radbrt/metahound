version: 1
sources:
    - name: postgres
      type: postgres
      connection:
        host: localhost
        username: postgres
        password: postgres
        database: postgres
      # Stats cost control (all optional): analyze: false skips stats
      # entirely; heavy opts in to COUNT(DISTINCT) per string column;
      # sample_percent uses TABLESAMPLE on big tables.
      # stats:
      #   heavy: true
      #   sample_percent: 5


